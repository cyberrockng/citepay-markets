# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets, but example is safe
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database (local only)
/data/

# contracts node_modules
/contracts/node_modules
/contracts/artifacts
/contracts/cache
/contracts/typechain-types

# secrets
.env.local
creator-wallets.json

# Stray files
*.deb
float-sign.mjs
.claude/

# dev wallet scripts with embedded keys - NEVER commit (Claude, 2026-07-04)
fund-agent.mjs
fund-agent2.mjs
float-sign.mjs
gen-agent.mjs
check-agent-bal.mjs
check-balance.mjs
creator-wallets.json
*.deb
