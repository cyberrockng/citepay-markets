# CitePay Markets — environment variable reference
# Copy to .env.local for local development.
# [required] vars must be set. [optional] vars degrade gracefully when unset.

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # [required] Claude Haiku for scoring, orchestration, outreach

# ── Agent wallet (viem / raw private key) ────────────────────────────────────
AGENT_PRIVATE_KEY=                  # [required] 0x… hex key — pays creators, anchors receipts on Arc Testnet
AGENT_WALLET_ADDRESS=               # [required] Corresponding public address of AGENT_PRIVATE_KEY
DEMO_BUYER_KEY=                     # [optional] Buyer key for demo-query; defaults to 0x1111…1111

# ── Circle Web3 Services (W3S) ───────────────────────────────────────────────
# Create a W3S project at console.circle.com → Developer → API Keys
CIRCLE_API_KEY=                     # [required] W3S API key
CIRCLE_ENTITY_SECRET=               # [required] W3S entity secret (hex, 32 bytes)
CIRCLE_WALLET_ID=                   # [required] W3S wallet ID (uuid)
CIRCLE_WALLET_SET_ID=               # [required] W3S wallet set ID (uuid)
CIRCLE_WALLET_ADDRESS=              # [required] Corresponding on-chain address for the W3S wallet
CIRCLE_GATEWAY_URL=                 # [optional] Defaults to https://gateway-api-testnet.circle.com

# ── Arc Testnet (chain 5042002) ───────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network   # [optional] Override RPC endpoint
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000  # [optional] USDC precompile
NEXT_PUBLIC_CONTRACT_ADDRESS=0x396cf1646EbAeF85ee8428C2d9239C46Ae956085  # [optional] CitePayMarket.sol
ARC_CITATION_MANDATE_ADDRESS=0xBad090764dd720B5EdcD8B49e054D5d8Ce13C695  # [optional] CitationMandate.sol
ARC_CREATOR_BOND_ADDRESS=0x7DBa1C67Fd9BA976aE09E744D8cbcC71F805D6C0     # [optional] CreatorBond.sol

# ── Neon Postgres (durable receipt storage) ───────────────────────────────────
# Provision at neon.tech; tables are auto-created on first run
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require  # [required] without this receipts are ephemeral

# ── Vercel Edge Config (cross-instance traction counters) ────────────────────
# Create in Vercel dashboard → Storage → Edge Config; connect to this project
EDGE_CONFIG=                        # [optional] https://edge-config.vercel.com/ecfg_xxx?token=yyy
EDGE_CONFIG_ID=                     # [optional] ecfg_xxx (ID only, used for write API)
EC_API_TOKEN=                       # [optional] Vercel API token scoped to read/write Edge Config
EC_TEAM_ID=                         # [optional] Vercel team ID (team_xxx) for Edge Config write calls

# ── Auth / security ──────────────────────────────────────────────────────────
REGISTER_API_KEY=                   # [required] Bearer token for POST /api/sources/register and /api/sources/reindex
CRON_SECRET=                        # [optional] Bearer token Vercel sends on cron invocations; recommended in prod
ADMIN_SECRET=                       # [optional] Bearer token for POST /api/admin/register-onchain
MCP_API_KEY=                        # [optional] Bearer token for POST /api/mcp; open if unset
REPLAY_GUARD_SECRET=                # [optional] HMAC secret for replay guard; has a safe default, override in prod
SUBSCRIPTION_SECRET=                # [optional] HMAC secret for subscription pass JWTs; has a safe default, override in prod

# ── Creator outreach (Resend) ────────────────────────────────────────────────
# Sign up at resend.com; free tier covers outreach volume
RESEND_API_KEY=                     # [optional] If unset, outreach emails are skipped silently

# ── Discord cron updates ──────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=                # [optional] Incoming webhook URL; if unset, discord-update cron is a no-op

# ── Public app URL ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://citepay-markets.vercel.app  # [optional] Falls back to VERCEL_URL in prod

# ── Auto-set by Vercel (do not set manually in Vercel dashboard) ──────────────
# VERCEL_URL   — deployment URL without https://
# VERCEL_ENV   — "production" | "preview" | "development"
# NODE_ENV     — "production" | "development"

# ── Scripts only (not needed for the Next.js app) ────────────────────────────
BASE_SEPOLIA_RPC_URL=               # [optional] Used by one-off funding scripts only
