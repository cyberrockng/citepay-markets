# ─── AI Agent ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Circle / x402 ────────────────────────────────────────────────────────────
CIRCLE_API_KEY=
CIRCLE_WALLET_ID=
USDC_TOKEN_ID=usdc

# ─── Blockchain (Arc Testnet) ─────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
DEPLOYER_PRIVATE_KEY=

# ─── Agent wallet (primary USDC payout path) ──────────────────────────────────
# Private key of an Arc Testnet wallet funded with USDC.
# When set, creator payouts are real on-chain ERC-20 transfers.
# If unset or balance is zero, falls back to deterministic tx hash (dev only).
AGENT_PRIVATE_KEY=

# USDC precompile on Arc Testnet
USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# Contract address (deployed CitePayMarket on Arc Testnet)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x396cf1646EbAeF85ee8428C2d9239C46Ae956085

# ─── Dev Mode ─────────────────────────────────────────────────────────────────
# Set to "true" to accept any x402 payment header without Circle verification
X402_DEV_MODE=true
NODE_ENV=development
